<script>
(function () {
  // --- HTML anchor generator: give every section heading a unique id ---
  function slugify(s) {
    return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 50);
  }
  var used = {};
  document.querySelectorAll('h2, h3').forEach(function (h) {
    var base = h.id || ('sec-' + (slugify(h.textContent) || 'section'));
    var id = base, n = 2;
    while (used[id]) { id = base + '-' + n; n++; }
    used[id] = true;
    h.id = id;
  });
  // --- Collect problematic sections: headings preceding an unanswered marker ---
  var seen = {}, items = [];
  document.querySelectorAll('.answer.placeholder').forEach(function (p) {
    var h = p.previousElementSibling;
    while (h && h.tagName !== 'H2' && h.tagName !== 'H3') h = h.previousElementSibling;
    if (h && !seen[h.id]) { seen[h.id] = true; items.push(h); }
  });
  // --- Build the jump list in the header ---
  var box = document.getElementById('attention');
  if (!box) return;
  if (!items.length) {
    box.innerHTML = '<p><strong>Sections needing attention:</strong> none detected \u2014 every section has at least one answer. Manual review is still recommended.</p>';
    return;
  }
  var html = '<p><strong>Sections needing attention (' + items.length + '):</strong> jump directly to review them.</p><ul>';
  items.forEach(function (h) {
    html += '<li><a href="#' + h.id + '">' + h.textContent + '</a></li>';
  });
  html += '</ul>';
  box.innerHTML = html;
})();
</script>

