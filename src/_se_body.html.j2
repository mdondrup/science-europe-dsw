{#- ---------------- helper macros ---------------- -#}

{#- Display string for a single reply: option/multichoice -> label,
    value/integration -> value. Anything else -> empty. -#}
{%- macro sval(r) -%}
  {%- if r is mapping -%}
    {%- if r._label is defined and r._label -%}{{ r._label }}
    {%- elif r._value is defined and r._value -%}{{ r._value }}
    {%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{#- Prose / option value.
    style A -> "**Label:** value" (own line).
    style C -> a full-sentence lead-in from `prose_leads` (fallback "Label:")
               followed by the value, flowing inline. -#}
{%- macro kv(label, key, r) -%}
  {%- set s = sval(r)|trim if r is mapping else (r|string|trim if r is not none else "") -%}
  {%- if s -%}
    {%- if style == 'C' -%}
      {%- set dot = "" if s.endswith((".", "!", "?", ";", ":")) else "." -%}
      {%- set lead = prose_leads.get(label) if prose_leads is defined else none -%}
      {%- if lead -%}{{- lead ~ " " ~ s ~ dot ~ " " -}}
      {%- else -%}{{- label ~ ": " ~ s ~ dot ~ " " -}}{%- endif -%}
    {%- else -%}
      {{- "**" ~ label ~ ":** " ~ s ~ "\n\n" -}}
    {%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{#- Multichoice.
    style A -> own line; style C -> `prose_leads` lead-in + joined labels. -#}
{%- macro kvmulti(label, key, lst) -%}
  {%- if lst -%}
    {%- set labels = lst | map(attribute='_label') | select | list -%}
    {%- if labels|length > 0 -%}
      {%- if style == 'C' -%}
        {%- set lead = prose_leads.get(label) if prose_leads is defined else none -%}
        {%- if lead -%}{{- lead ~ " " ~ (labels|join(", ")) ~ ". " -}}
        {%- else -%}{{- label ~ ": " ~ (labels|join(", ")) ~ ". " -}}{%- endif -%}
      {%- else -%}{{- "**" ~ label ~ ":** " ~ (labels|join(", ")) ~ "\n\n" -}}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{#- Yes/No question.
    style A -> "**Label:** Yes/No" (nothing if unanswered).
    style C -> one of three pre-written, grammatical sentences:
      `yes` when answered yes, `no` when answered no,
      `undef` (an "It is undefined whether ..." sentence) when unanswered. -#}
{%- macro yn(label, key, r, yes, no, undef) -%}
  {%- set s = sval(r)|trim -%}
  {%- if style == 'C' -%}
    {%- set sl = s|lower -%}
    {%- if sl.startswith("yes") -%}{{- yes ~ " " -}}
    {%- elif sl.startswith("no") -%}{{- no ~ " " -}}
    {%- else -%}{{- undef ~ " " -}}
    {%- endif -%}
  {%- else -%}
    {%- if s -%}{{- "**" ~ label ~ ":** " ~ s ~ "\n\n" -}}{%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{#- Render the answer block, or a visible marker when nothing was produced. -#}
{%- macro answers(content) -%}
{%- if content and content|trim -%}
{{ content|markdown }}
{%- else -%}
<p class="answer placeholder"><em>(no answer in this project export — review KM mapping/coverage)</em></p>
{%- endif %}
{%- endmacro -%}

